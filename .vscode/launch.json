{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Debug VM",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/debug/vm.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/out/debug",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "Ninja Build Debug"
        },
        {
            "name": "(Windows) Debug Unittests",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/ut/ut.exe",
            "args": [
                "--gtest_break_on_failure",
                "--gtest_catch_exceptions=0"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/out/ut",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "Ninja Build Unittests"
        },
        {
            "name": "(Windows) Embedder Demo Unittests",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/embedder_demo/embedder_game_engine_demo.exe",
            "args": [
                "--gtest_break_on_failure",
                "--gtest_catch_exceptions=0"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/out/embedder_demo",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "Ninja Build EembedderDemo"
        }
    ]
}