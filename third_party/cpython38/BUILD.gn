declare_args() {
  # 默认为当前目录 (//third_party/cpython38)
  python38_root = "."
  python38_extra_libs = []
  python38_extra_ldflags = []
}

config("python38_config") {
  if (is_win) {
    _include_dir = "$python38_root/include_win"
  } else if (is_linux) {
    _include_dir = "$python38_root/include_linux"
  }

  if (is_win) {
    _lib_dir = "$python38_root/lib_win"
  } else if (is_linux) {
    _lib_dir = "$python38_root/lib_linux"
  }

  include_dirs = [ _include_dir ]

  if (is_win) {
    _lib_name = "python38.lib"
  } else if (is_linux) {
    _lib_name = "python3.8"
  }

  libs = [ _lib_name ] + python38_extra_libs
  if (is_win) {
    ldflags = [ "/LIBPATH:" + rebase_path(_lib_dir, root_build_dir) ] +
              python38_extra_ldflags
  } else {
    lib_dirs = [ _lib_dir ]
    ldflags = python38_extra_ldflags + [ "-no-pie" ]
    libs += [
      "util",
      "expat",
      "dl",
      "pthread",
      "m",
      "z",
    ]
  }
  defines = [ "PY_SSIZE_T_CLEAN" ]
}

source_set("cpython38") {
  public_configs = [ ":python38_config" ]
}
