  deps = [ ":saauso_core" ]
  public_configs = [ ":saauso_public_api_includes" ]
}

# -----------------------------------------------------------------------------
# CLI 可执行入口（开发调试用）
# -----------------------------------------------------------------------------
executable("vm") {
  sources = [ "//src/main.cc" ]
  deps = [ ":saauso_core" ]
}

# -----------------------------------------------------------------------------
# Embedder 示例（Phase0/1 验证样例）
# -----------------------------------------------------------------------------
executable("embedder_hello_world") {
  testonly = true
  sources = [ "//samples/hello-world.cc" ]
  deps = [ ":embedder_api" ]
}

executable("embedder_game_engine_demo") {
  testonly = true
  sources = [ "//samples/game-engine-demo.cc" ]
  deps = [ ":embedder_api" ]
}

# -----------------------------------------------------------------------------
# 统一测试入口
# -----------------------------------------------------------------------------
# 说明：
# - 保留既有 test/unittests:ut 作为主回归集合。
# - 额外纳入 Embedder Phase0/1 的边界检查与单测，确保演进不回退。
group("all_ut") {
  testonly = true
  deps = [
    "//test/embedder:embedder_ut",
    "//test/unittests:ut",
  ]
}
