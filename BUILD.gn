# -----------------------------------------------------------------------------
# 可选前端：CPython312 编译器桥接
# -----------------------------------------------------------------------------
# 受 saauso_enable_cpython_compiler 开关控制：
# - true : 启用 pyc 编译前端相关实现并链接 third_party/cpython312
# - false: 仅保留后端执行链路，适合纯后端回归和无 Python 开发库环境
source_set("saauso_cpython312_compiler") {
  # 理论上 saauso_cpython312_compiler 作为基础组件，
  # 不应该对除虚拟机内核 saauso_core 之外的任何依赖开放！
  #
  # 不过 ut 是一个特例，因为它其中包含了针对
  # saauso_cpython312_compiler 的单测！
  visibility = [
    "//:saauso_core",
    "//test/unittests:ut",
  ]

  if (saauso_enable_cpython_compiler) {
    sources = [
      "//src/code/cpython312-pyc-compiler.cc",
      "//src/code/cpython312-pyc-compiler.h",
    ]

    deps = [
      "//build:build_helper_headers",
      "//third_party/cpython312",
    ]

    configs += [
      ":saauso_includes",
      "//third_party/cpython312:python312_config",
    ]

    all_dependent_configs = [ "//third_party/cpython312:python312_config" ]
  } else {
    sources = []
  }
}

# -----------------------------------------------------------------------------
# Embedder API 目标（Phase0/1）
# -----------------------------------------------------------------------------
# 该目标承载 include/saauso-embedder.h + src/api/* 桥接实现。
# 关键约束：
# 1) 对外只通过 saauso_public_api_includes 暴露 include/。
# 2) 在开启 cpython 前端时，需显式依赖 saauso_cpython312_compiler，
#    否则可能出现链接期缺符号（如 EmbeddedPython312Compiler::*）。
source_set("embedder_api") {
  sources = [
    # 暴露给嵌入方的头文件
    "//include/saauso-container.h",
    "//include/saauso-context.h",
    "//include/saauso-exception.h",
    "//include/saauso-function-callback.h",
    "//include/saauso-function.h",
    "//include/saauso-isolate.h",
    "//include/saauso-local-handle.h",
    "//include/saauso-locker.h",
    "//include/saauso-object.h",
    "//include/saauso-primitive.h",
    "//include/saauso-script.h",
    "//include/saauso-value.h",
    "//include/saauso.h",

    # API 内部实现
    "//src/api/api-bridge-access.h",
    "//src/api/api-container.cc",
    "//src/api/api-context.cc",
    "//src/api/api-exception-support.cc",
    "//src/api/api-exception-support.h",
    "//src/api/api-exception.cc",
    "//src/api/api-function-callback-support.cc",
    "//src/api/api-function-callback-support.h",
    "//src/api/api-function-callback.cc",
    "//src/api/api-function.cc",
    "//src/api/api-handle-utils.h",
    "//src/api/api-isolate-utils.h",
    "//src/api/api-isolate.cc",
    "//src/api/api-local-handle.cc",
