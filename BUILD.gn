# =============================================================================
# 根 BUILD 维护说明（请先阅读）
# =============================================================================
# 1) 该文件负责定义：
#    - VM 核心实现目标（saauso_core）
#    - 可选的 CPython312 前端编译器目标（saauso_cpython312_compiler）
#    - Embedder API 及示例目标（embedder_api / embedder_hello_world）
#    - 统一测试入口（ut）
# 2) 依赖方向约束：
#    - 上层目标可依赖 saauso_core，但 saauso_core 不依赖上层目标。
#    - embedder_api 是对 saauso_core 的包装层，后续 Phase2+ 继续扩展。
# 3) 修改建议：
#    - 新增核心源码优先放入 saauso_core 的对应分区。
#    - 新增对外 API 相关实现放入 src/api，并挂入 embedder_api。
#    - 新增 Embedder 示例需同时纳入头文件边界检查 action。
# =============================================================================

# 宽 include 配置：面向核心目标与历史测试目标，允许使用仓库根路径做 include 根。
# 说明：这是“内部开发便利”配置，不等价于“对外 API 边界”。
config("saauso_includes") {
  include_dirs = [ "//" ]
}

# 窄 include 配置：面向 Embedder 对外目标，仅暴露 include/。
# 说明：后续外部工程接入应以该配置为准，避免误依赖 src/** 内部头。
config("saauso_public_api_includes") {
  include_dirs = [ "//include" ]
}

# -----------------------------------------------------------------------------
# 供 VN 内核和上层依赖方公用的基础设施头文件
# -----------------------------------------------------------------------------
source_set("saauso_infra_public_headers") {
  sources = [
    "//include/saauso-initialization.h",
    "//include/saauso-maybe.h",
  ]
}

